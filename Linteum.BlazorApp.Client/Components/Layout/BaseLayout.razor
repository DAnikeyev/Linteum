@inject LocalStorageService LocalStorageService
@inject NavigationManager Navigation
@inject ILogger<BaseLayout> Logger
@inject MyApiClient ApiClient
@inject IConfiguration Configuration
@inject SidebarStateService SidebarState
@inherits LayoutComponentBase
@implements IDisposable

<CanvasSidebar />

<main class="main-content" style="margin-left:@_sidebarMargin;">
    <CascadingValue Value="_sidebarMargin" Name="SidebarMargin">
        @Body
    </CascadingValue>
    @if (!string.IsNullOrWhiteSpace(HubLink))
    {
        <a class="btn btn-outline-primary hub-back-btn"
           href="@HubLink"
           style="left: calc(@_sidebarMargin + 12px);">
            <i class="bi bi-arrow-left me-1"></i>
            Back to hub
        </a>
    }
    <div class="version-label">
        @($"v{Version}")
    </div>
</main>

<NotificationManager />

@code {
    private string _sidebarMargin = "300px";
    private string Version => Configuration["VERSION"] ?? Environment.GetEnvironmentVariable("VERSION") ?? "dev";
    private string HubLink
    {
        get
        {
            var link = Configuration["HUB_LINK"] ?? Environment.GetEnvironmentVariable("HUB_LINK");
            if (string.IsNullOrEmpty(link)) return string.Empty;
            return link.StartsWith("http") ? link : $"https://{link}";
        }
    }

    protected override void OnInitialized()
    {
        _sidebarMargin = SidebarState.CurrentMargin;
        SidebarState.MarginChanged += OnSidebarMarginChanged;
    }

    private void OnSidebarMarginChanged(string margin)
    {
        _sidebarMargin = margin;
        _ = InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ValidateLocally();
        }
    }

    public async Task ValidateLocally()
    {
        try
        {
            var sessionIdString = await LocalStorageService.GetItemAsync<string>(LocalStorageKey.SessionId);
            if (sessionIdString == null || !Guid.TryParse(sessionIdString, out var sessionId))
            {
                Logger.LogInformation("No valid session ID found, redirecting to login.");
                await LocalStorageService.ClearAsync();
                ApiClient.ClearSession();
                Navigation.NavigateTo("/login");
                return;
            }

            Logger.LogInformation("Validating session with server.");
            var (user, validatedSessionId) = await ApiClient.LoginAsync(sessionId);

            if (user == null || validatedSessionId == null)
            {
                Logger.LogInformation("Session validation failed, redirecting to login.");
                await LocalStorageService.ClearAsync();
                ApiClient.ClearSession();
                Navigation.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error validating session, redirecting to login.");
            await LocalStorageService.ClearAsync();
            ApiClient.ClearSession();
            Navigation.NavigateTo("/login");
        }
    }

    public void Dispose()
    {
        SidebarState.MarginChanged -= OnSidebarMarginChanged;
    }
}

