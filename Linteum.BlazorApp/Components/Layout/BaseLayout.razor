@inject LocalStorageService LocalStorageService
@inject NavigationManager Navigation
@inject ILogger<BaseLayout> Logger
@inject MyApiClient ApiClient
@inject IConfiguration Configuration
@using Linteum.BlazorApp.Components.Notification
@inherits LayoutComponentBase


<CascadingValue Value="Sidebar">
    <CascadingValue Value="_notificationManagerRef">
        <CanvasSidebar @ref="Sidebar" CollapsedChanged="OnSidebarCollapsedChanged" />
    </CascadingValue>

    <main class="main-content" style="margin-left:@SidebarMargin;">
        <CascadingValue Value="SidebarMargin" Name="SidebarMargin">
            @Body
        </CascadingValue>
        @if (!string.IsNullOrWhiteSpace(HubLink))
        {
            <a class="btn btn-outline-primary hub-back-btn"
               href="@HubLink"
               style="left: calc(@SidebarMargin + 12px);">
                <i class="bi bi-arrow-left me-1"></i>
                Back to hub
            </a>
        }
        <div class="version-label">
            @($"v{Version}")
        </div>
    </main>

    <NotificationManager @ref="_notificationManagerRef" />
</CascadingValue>
@code {
    private const string SidebarWidth = "300px";
    public CanvasSidebar? Sidebar { get; set; }
    private NotificationManager? _notificationManagerRef;
    private bool _isSidebarCollapsed;
    private string Version => Configuration["VERSION"] ?? Environment.GetEnvironmentVariable("VERSION") ?? "dev";
    private string SidebarMargin => _isSidebarCollapsed ? "0px" : SidebarWidth;
    private string HubLink
    {
        get
        {
            var link = Configuration["HUB_LINK"] ?? Environment.GetEnvironmentVariable("HUB_LINK");
            if (string.IsNullOrEmpty(link)) return string.Empty;
            return link.StartsWith("http") ? link : $"https://{link}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ValidateLocally();
        }
    }

    public async Task ValidateLocally()
    {
        try
        {
            var sessionIdString = await LocalStorageService.GetItemAsync<string>(LocalStorageKey.SessionId);
            if (sessionIdString == null || !Guid.TryParse(sessionIdString, out var sessionId))
            {
                Logger.LogInformation("No valid session ID found, redirecting to login.");
                await LocalStorageService.ClearAsync();
                ApiClient.ClearSession();
                Navigation.NavigateTo("/login");
                return;
            }

            Logger.LogInformation("Validating session with server.");
            var (user, validatedSessionId) = await ApiClient.LoginAsync(sessionId);

            if (user == null || validatedSessionId == null)
            {
                Logger.LogInformation("Session validation failed, redirecting to login.");
                await LocalStorageService.ClearAsync();
                ApiClient.ClearSession();
                Navigation.NavigateTo("/login");
            }
            else
            {
                Logger.LogInformation("Session validated successfully.");
            }
        }
        catch(Exception ex)
        {
            Logger.LogError($"Error {ex} validating session, redirecting to login.");
            await LocalStorageService.ClearAsync();
            ApiClient.ClearSession();
            Navigation.NavigateTo("/login");
        }
    }

    private void OnSidebarCollapsedChanged(bool isCollapsed)
    {
        if (_isSidebarCollapsed == isCollapsed)
        {
            return;
        }

        _isSidebarCollapsed = isCollapsed;
        StateHasChanged();
    }

}
