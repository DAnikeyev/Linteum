@inject LocalStorageService LocalStorageService
@inject NavigationManager Navigation
@inject ILogger<BaseLayout> Logger
@inject MyApiClient ApiClient
@using Linteum.BlazorApp.Components.Notification
@inherits LayoutComponentBase


<CascadingValue Value="Sidebar">
    <CascadingValue Value="_notificationManagerRef">
        <CanvasSidebar @ref="Sidebar" CollapseToggled="OnSidebarCollapseChanged" />
    </CascadingValue>

    <main style="margin-left:@_sidebarMargin; background: linear-gradient(135deg, var(--sb-bg) 0%, var(--pm-bg-color) 100%); min-height: 100vh; padding: 1rem; position: relative;">
        <CascadingValue Value="_sidebarMargin" Name="SidebarMargin">
            @Body
        </CascadingValue>
    </main>

    <NotificationManager @ref="_notificationManagerRef" />
</CascadingValue>
@code {
    public CanvasSidebar? Sidebar { get; set; }
    private string _sidebarMargin = "300px";
    private NotificationManager? _notificationManagerRef;

    private void OnSidebarCollapseChanged(bool isCollapsed)
    {
        _sidebarMargin = isCollapsed ? "0px" : "300px";
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ValidateLocally();
        }
    }

    public async Task ValidateLocally()
    {
        try
        {
            var sessionIdString = await LocalStorageService.GetItemAsync<string>(LocalStorageKey.SessionId);
            if (sessionIdString == null || !Guid.TryParse(sessionIdString, out var sessionId))
            {
                Logger.LogInformation("No valid session ID found, redirecting to login.");
                await LocalStorageService.ClearAsync();
                ApiClient.ClearSession();
                Navigation.NavigateTo("/login");
                return;
            }

            Logger.LogInformation("Validating session with server.");
            var (user, validatedSessionId) = await ApiClient.LoginAsync(sessionId);

            if (user == null || validatedSessionId == null)
            {
                Logger.LogInformation("Session validation failed, redirecting to login.");
                await LocalStorageService.ClearAsync();
                ApiClient.ClearSession();
                Navigation.NavigateTo("/login");
            }
            else
            {
                Logger.LogInformation("Session validated successfully.");
            }
        }
        catch(Exception ex)
        {
            Logger.LogError($"Error {ex} validating session, redirecting to login.");
            await LocalStorageService.ClearAsync();
            ApiClient.ClearSession();
            Navigation.NavigateTo("/login");
        }
    }

}
