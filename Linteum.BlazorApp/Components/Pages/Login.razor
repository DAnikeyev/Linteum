@page "/"
@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@implements IDisposable
@using Linteum.BlazorApp.Components.Layout
@using Linteum.Shared
@inject NavigationManager Navigation
@inject MyApiClient ApiClient
@inject Config Config
@inject LocalStorageService LocalStorageService
@inject ILogger<Login> Logger
@inject IJSRuntime JS

<div class="background">
    <div class="brand-title">LINTEUM</div>
    @if (!_isAuthResolved || _isBusy)
    {
        <div class="login-container auth-card auth-loading-card">
            <div class="auth-header">
                <h3>@_busyTitle</h3>
                <p>@_busyMessage</p>
            </div>

            <div class="loading-spinner-wrap compact">
                <div class="loading-spinner"></div>
            </div>
        </div>
    }
    else
    {
        <div class="login-container auth-card">
            <div class="auth-header">
                <h3>Login</h3>
                <p>Continue to your canvases and live collaborations.</p>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <form @onsubmit="HandleLogin" @onsubmit:preventDefault>
                <!-- Email -->
                <div class="mb-4">
                    <label for="emailInput" class="form-label">Email</label>
                    <input id="emailInput" class="form-control fixed-width" @bind="_email" @bind:event="oninput" @bind:after="ClearError" />
                    @if (!string.IsNullOrEmpty(_emailError))
                    {
                        <div class="text-danger mt-1">@_emailError</div>
                    }
                </div>

                <!-- Password -->
                <div class="mb-4">
                    <label for="passwordInput" class="form-label">
                        Password
                        <span class="field-hint"
                              title="We don't store unhashed passwords. We don't use your email for anything except login."
                              aria-label="Security and privacy info">?</span>
                    </label>
                    <input id="passwordInput" type="password" class="form-control fixed-width" @bind="_password" @bind:event="oninput" @bind:after="ClearError" />
                    @if (!string.IsNullOrEmpty(_passwordError))
                    {
                        <div class="text-danger mt-1">@_passwordError</div>
                    }
                </div>

                <!-- Buttons -->
                <div class="d-flex gap-2 login-actions">
                    <button class="btn btn-primary flex-fill" type="submit">Login</button>
                    <button class="btn btn-outline-primary flex-fill"
                            type="button"
                            @onclick="GoogleLoginAsync"
                            disabled="@(!_isGoogleEnabled)">
                        Google Login
                    </button>
                </div>
            </form>
            <p class="auth-switch">
                Don&#39;t have an account? <a href="/signup">Sign up</a>
            </p>
        </div>
    }
</div>

@code {
    private static readonly TimeSpan AuthOperationTimeout = TimeSpan.FromSeconds(10);
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string? _emailError;
    private string? _passwordError;
    private string? _error;
    private DotNetObjectReference<Login>? _googleLoginReference;
    private bool _isGoogleInitialized;
    private bool _isAuthResolved;
    private bool _isBusy = true;
    private string _busyTitle = "Checking session";
    private string _busyMessage = "Checking whether you are already signed in.";
    private bool _isGoogleEnabled => !string.IsNullOrWhiteSpace(Config.GoogleClientId);

    private void ClearError()
    {
        _emailError = null;
        _passwordError = null;
        _error = null;
    }

    private async Task HandleLogin()
    {
        _emailError = null;
        _passwordError = null;
        _error = null;

        if (string.IsNullOrWhiteSpace(_email))
            _emailError = "Email is required.";
        else if (!_email.Contains("@") || !_email.Contains("."))
            _emailError = "Enter a valid email address.";

        if (string.IsNullOrWhiteSpace(_password))
            _passwordError = "Password is required.";
        else if (_password.Length < 4 || _password.Length > 32)
            _passwordError = "Password must be 4-32 characters.";

        if (_emailError != null || _passwordError != null)
            return;

        SetBusyState("Signing in", "Verifying your credentials.");
        try
        {
            Logger.LogInformation("Login attempt for {Email}", _email);
            var (user, sessionId) = await WithAuthTimeoutAsync(ApiClient.LoginAsync(_email, _password), "Password login");
            if (user != null)
            {
                Logger.LogInformation("Login successful for {Email}", _email);
                Navigation.NavigateTo(Config.DefaultPage, replace: true);
                return;
            }

            Logger.LogWarning("Login failed for {Email}", _email);
            _error = "Invalid login credentials.";
        }
        catch (TimeoutException ex)
        {
            Logger.LogWarning(ex, "Login timed out for {Email}", _email);
            _error = "Login timed out. Please try again.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Login failed for {Email}", _email);
            _error = "Could not sign in right now. Please try again.";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task GoogleLoginAsync()
    {
        _error = null;
        if (!_isGoogleEnabled)
        {
            _error = "Google login is not configured.";
            return;
        }

        if (!_isGoogleInitialized)
        {
            await InitializeGoogleAsync();
        }

        if (!_isGoogleInitialized)
        {
            _error = "Google login is currently unavailable.";
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("googleAuth.prompt");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to start Google login flow.");
            _error = "Could not start Google login. Please try again.";
        }
    }

    [JSInvokable]
    public async Task OnGoogleCodeReceived(string authCode)
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(authCode))
        {
            _error = "Google login failed because no authorization code was returned.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        SetBusyState("Signing in", "Completing Google sign-in.");
        try
        {
            var (user, sessionId, error) = await WithAuthTimeoutAsync(
                ApiClient.LoginWithGoogleCodeAsync(authCode),
                "Google login");

            if (user != null && sessionId != null)
            {
                Logger.LogInformation("Google login successful for {Email}", user.Email);
                Navigation.NavigateTo(Config.DefaultPage, replace: true);
                return;
            }

            _error = string.IsNullOrWhiteSpace(error) ? "Google login failed." : error;
        }
        catch (TimeoutException ex)
        {
            Logger.LogWarning(ex, "Google login timed out.");
            _error = "Google login timed out. Please try again.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Google login failed.");
            _error = "Could not complete Google login. Please try again.";
        }
        finally
        {
            _isBusy = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnGoogleError(string error)
    {
        _error = string.IsNullOrWhiteSpace(error)
            ? "Google login was canceled or blocked."
            : $"Google login failed: {error}";
        _isBusy = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task InitializeGoogleAsync()
    {
        if (!_isGoogleEnabled)
        {
            return;
        }

        try
        {
            _googleLoginReference ??= DotNetObjectReference.Create(this);
            _isGoogleInitialized = await JS.InvokeAsync<bool>("googleAuth.initialize", Config.GoogleClientId, _googleLoginReference);
            if (!_isGoogleInitialized)
            {
                Logger.LogWarning("Google Identity Services is not ready on login page.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize Google Identity Services.");
            _isGoogleInitialized = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Logger.LogInformation("Hello, login page!");
            var shouldRenderLogin = true;
            try
            {
                var sessionIdString = await WithAuthTimeoutAsync(
                    LocalStorageService.GetItemAsync<string>(LocalStorageKey.SessionId),
                    "Reading saved session");

                if (sessionIdString != null && Guid.TryParse(sessionIdString, out var sessionId))
                {
                    Logger.LogInformation("Session ID found, validating with server.");
                    var (user, validatedSessionId) = await WithAuthTimeoutAsync(
                        ApiClient.LoginAsync(sessionId),
                        "Validating session");

                    if (user != null && validatedSessionId != null)
                    {
                        Logger.LogInformation("Session validated successfully, redirecting to home page.");
                        shouldRenderLogin = false;
                        Navigation.NavigateTo(Config.DefaultPage, replace: true);
                    }
                    else
                    {
                        Logger.LogInformation("Session validation failed, clearing local storage.");
                        await LocalStorageService.ClearAsync();
                        ApiClient.ClearSession();
                    }
                }
                else
                {
                    Logger.LogInformation("No valid session ID found, staying on login page.");
                }
            }
            catch (TimeoutException ex)
            {
                Logger.LogWarning(ex, "Session check timed out on login page.");
                _error = "Session check timed out. Please sign in manually.";
                await ClearStoredSessionSafelyAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error checking session validity on login page.");
                _error = "Could not verify your session. Please sign in again.";
                await ClearStoredSessionSafelyAsync();
            }
            finally
            {
                if (shouldRenderLogin)
                {
                    await InitializeGoogleAsync();
                    _isAuthResolved = true;
                    _isBusy = false;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
    }

    private async Task<T> WithAuthTimeoutAsync<T>(Task<T> task, string operationName)
    {
        try
        {
            return await task.WaitAsync(AuthOperationTimeout);
        }
        catch (TimeoutException ex)
        {
            throw new TimeoutException($"{operationName} timed out after {AuthOperationTimeout.TotalSeconds:0} seconds.", ex);
        }
    }

    private async Task ClearStoredSessionSafelyAsync()
    {
        try
        {
            await LocalStorageService.ClearAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to clear local storage after login session check failure.");
        }

        ApiClient.ClearSession();
    }

    private void SetBusyState(string title, string message)
    {
        _busyTitle = title;
        _busyMessage = message;
        _isBusy = true;
    }

    public void Dispose()
    {
        _googleLoginReference?.Dispose();
    }
}
