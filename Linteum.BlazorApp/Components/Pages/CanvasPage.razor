@page "/canvas/{canvasName}"
@layout Layout.BaseLayout
@using Linteum.BlazorApp.Components.Notification
@using Linteum.Shared.DTO
@using NLog
@inject IConfiguration Configuration
@using Linteum.BlazorApp.Components.Layout
@using Microsoft.AspNetCore.Components.Web
@using Linteum.Shared
@using Linteum.BlazorApp.Services
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject MyApiClient ApiClient
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject LocalStorageService LocalStorageService
@inject NavigationManager NavigationManager
@using Microsoft.Extensions.Hosting
@inject IHostEnvironment Environment

<div class="canvas-page-container">
    @if (!_canvasReady)
    {
        <div class="canvas-loading-overlay">
            <div class="loading-spinner"></div>
        </div>
    }

    @if (_canvas != null)
    {
        <div class="canvas-shell @(_canvasReady ? "ready" : "")">
            <div @ref="_viewportHostRef" class="canvas-stage">
                <div @ref="_viewportRef" class="canvas-viewport"
                     style="width:@(ViewportWidth)px; height:@(ViewportHeight)px;">

                    <div @ref="_rendererRef" class="canvas-renderer"
                         style="position: absolute; background:#ffffff;">

                        <canvas @ref="_canvasRef"
                                width="@_canvas.Width"
                                height="@_canvas.Height"
                                style="width:100%; height:100%; display:block; pointer-events:none; image-rendering:pixelated;">
                        </canvas>

                        <canvas @ref="_overlayRef"
                                width="@_canvas.Width"
                                height="@_canvas.Height"
                                style="width:100%; height:100%; display:block; pointer-events:none; image-rendering:pixelated; position:absolute; top:0; left:0;">
                        </canvas>

                    </div>
                </div>
            </div>

            <PixelManager @ref="_pixelManager" Canvas="@_canvas" ClickedPixel="@_clickedPixel" ClickedPixelData="@_clickedPixelData" CanvasRenderer="@_renderer" OnlineUsers="@_onlineUsers" />
        </div>

        <div @ref="_coordsDisplayRef" class="canvas-coordinates"
             style="left: calc(@(SidebarMargin) + 12px);"></div>
    }
</div>

@code {
    [Parameter]
    public string canvasName { get; set; } = default!;

    [CascadingParameter(Name = "SidebarMargin")]
    public string SidebarMargin { get; set; } = "300px";

    private static readonly Logger _nlog = LogManager.GetCurrentClassLogger();

    private CanvasDto? _canvas;
    private string? _loadedCanvasName;
    private (int X, int Y)? _clickedPixel;
    private PixelDto? _clickedPixelData;

    // SignalR
    private HubConnection? _hubConnection;
    private string? _connectedGroup;
    private List<string> _onlineUsers = new();

    // Renderer
    private ElementReference _canvasRef;
    private ElementReference _overlayRef;
    private CanvasRenderer? _renderer;

    // Viewport element refs (passed to JS controller)
    private ElementReference _viewportHostRef;
    private ElementReference _viewportRef;
    private ElementReference _rendererRef;
    private ElementReference _coordsDisplayRef;

    // Viewport dimensions
    private double ViewportWidth { get; set; } = 900;
    private double ViewportHeight { get; set; } = 600;

    // State tracking
    private bool _hasRendered = false;
    private bool _canvasReady = false;
    private string _lastSidebarMargin = "300px";
    private List<ColorDto>? _colors;
    private DotNetObjectReference<CanvasPage>? _objRef;
    private IJSObjectReference? _resizeListener;
    private int _canvasLoadVersion;
    private bool _jsViewportInitialized;
    private bool _pendingViewportRefresh = true;

    // PixelManager reference
    private PixelManager? _pixelManager;

            
    // LIFECYCLE: SETUP SIGNALR
    protected override async Task OnInitializedAsync()
    {
        try 
        {
            var apiBase = Configuration["ApiBaseUrl"]; 
            
            if (string.IsNullOrEmpty(apiBase)) 
            {
                _nlog.Warn("ApiBaseUrl missing from config, defaulting to /canvashub relative to page.");
                apiBase = NavigationManager.BaseUri;
            }

            var hubUrl = $"{apiBase.TrimEnd('/')}/canvashub";
            var sessionId = await LocalStorageService.GetItemAsync<string>(LocalStorageKey.SessionId);

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(hubUrl, options =>
                {
                    options.Headers[CustomHeaders.SessionId] = sessionId;
                    if (Environment.IsDevelopment())
                    {
                        options.HttpMessageHandlerFactory = (handler) =>
                        {
                            if (handler is HttpClientHandler clientHandler)
                            {
                                clientHandler.ServerCertificateCustomValidationCallback = (_, _, _, _) => true;
                            }
                            return handler;
                        };
                        options.WebSocketConfiguration = socketOptions =>
                        {
                            socketOptions.RemoteCertificateValidationCallback = (_, _, _, _) => true;
                        };
                    }
                })
                .WithAutomaticReconnect()
                .Build();
            
            _nlog.Info($"SignalR HubConnection built for {hubUrl}, starting connection...");

            _hubConnection.On<int, int, int>("ReceivePixelUpdate", async (x, y, colorId) =>
            {
                if (_renderer == null || _colors == null) return;

                var currentCanvasName = _canvas?.Name ?? canvasName;
                var selectedPixelId = _clickedPixel.HasValue && _clickedPixel.Value.X == x && _clickedPixel.Value.Y == y
                    ? _clickedPixelData?.Id
                    : null;
                ApiClient.HandlePixelColorChanged(currentCanvasName, x, y, colorId, selectedPixelId);

                // Try to find the color hex from the ID sent
                var c = _colors.FirstOrDefault(cDto => cDto.Id == colorId);
                if (c != null)
                {
                    _renderer.EnqueuePixel(x, y, c.HexValue);
                }

                // Update pixel history if this pixel is currently selected
                if (_clickedPixel.HasValue && _clickedPixel.Value.X == x && _clickedPixel.Value.Y == y && _pixelManager != null)
                {
                    if (_clickedPixelData != null)
                    {
                        _clickedPixelData.ColorId = colorId;
                        if (_clickedPixelData.Id.HasValue)
                        {
                            ApiClient.InvalidateHistoryCache(_clickedPixelData.Id.Value);
                        }
                    }

                    await _pixelManager.UpdatePixelHistory();
                    await InvokeAsync(StateHasChanged);
                }
            });

            _hubConnection.On<List<string>>("UpdateOnlineUsers", (users) =>
            {
                _onlineUsers = users;
                InvokeAsync(StateHasChanged);
            });
            
            _hubConnection.Reconnected += async (_) =>
            {
                if (!string.IsNullOrEmpty(_connectedGroup))
                {
                    await _hubConnection.InvokeAsync("JoinCanvasGroup", _connectedGroup);
                }
            };

            await _hubConnection.StartAsync();
        }
        catch(Exception ex)
        {
            _nlog.Error(ex, "Failed to start SignalR connection");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _hasRendered = true;
            _lastSidebarMargin = SidebarMargin;
            _pendingViewportRefresh = true;

            _objRef = DotNetObjectReference.Create(this);
            _resizeListener = await JSRuntime.InvokeAsync<IJSObjectReference>("canvasHelpers.registerResizeListener", _objRef);
        }

        if (_canvas != null && _renderer == null)
        {
            // 1. Calculate the real viewport from the rendered host area first
            await CalculateViewportDimensions();
            _pendingViewportRefresh = false;
            StateHasChanged();

            // 2. Initialize the renderer and load the image (awaitable – no white flash)
            _renderer = new CanvasRenderer(JSRuntime);
            await _renderer.InitializeAsync(_canvasRef, _overlayRef);
            await LoadCanvasImage();

            // 3. Initialize JS viewport (fit + center) now that dimensions are correct
            await InitJsViewport();

            // 3.5. Request one more post-init fit after the shell is visible.
            // Some deployed layouts settle after first paint, which can skew the first measurement.
            _pendingViewportRefresh = true;

            // 4. Reveal the canvas shell with a smooth fade-in
            _canvasReady = true;
            StateHasChanged();
            return;
        }

        if (_pendingViewportRefresh && _canvas != null && _jsViewportInitialized)
        {
            await CalculateViewportDimensions();
            _pendingViewportRefresh = false;
            await JSRuntime.InvokeVoidAsync("canvasViewport.fitCanvas", ViewportWidth, ViewportHeight);
            StateHasChanged();
        }
    }

    private async Task InitJsViewport()
    {
        if (_canvas == null || _objRef == null) return;
        _jsViewportInitialized = true;
        await JSRuntime.InvokeVoidAsync("canvasViewport.init",
            _objRef, _viewportRef, _rendererRef, _coordsDisplayRef,
            _canvas.Width, _canvas.Height,
            ViewportWidth, ViewportHeight);
    }

    [JSInvokable]
    public async Task OnPixelClicked(int x, int y)
    {
        if (_canvas == null) return;

        _clickedPixel = (x, y);
        _clickedPixelData = await ApiClient.GetPixelData(_canvas.Name, x, y, useCache: true);

        if (_clickedPixelData != null && _colors != null)
        {
            var color = _colors.FirstOrDefault(c => c.Id == _clickedPixelData.ColorId);
            if (color != null && _renderer != null)
            {
                _renderer.EnqueuePixel(x, y, color.HexValue);
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnWindowResize()
    {
        await CalculateViewportDimensions();
        if (_jsViewportInitialized)
        {
            await JSRuntime.InvokeVoidAsync("canvasViewport.fitCanvas", ViewportWidth, ViewportHeight);
        }
        StateHasChanged();
    }

    private async Task CalculateViewportDimensions()
    {
        try
        {
            var hostSize = await JSRuntime.InvokeAsync<ElementSize>("canvasHelpers.getElementSize", _viewportHostRef);
            if (hostSize.Width > 0 && hostSize.Height > 0)
            {
                ViewportWidth = Math.Max(100, hostSize.Width);
                ViewportHeight = Math.Max(100, hostSize.Height);
                return;
            }

            var m = await JSRuntime.InvokeAsync<LayoutMetrics>("canvasHelpers.getLayoutMetrics");

            const double safetyPadding = 2;
            var isMobile = m.WindowWidth <= 768;

            if (isMobile)
            {
                const double mobileBottomSheetHeader = 56;
                ViewportWidth = Math.Max(100, m.WindowWidth - m.MainHPad - safetyPadding);
                ViewportHeight = Math.Max(100, m.WindowHeight - m.MainVPad - mobileBottomSheetHeader - safetyPadding);
            }
            else
            {
                double sidebarWidth = 300;
                if (!string.IsNullOrEmpty(SidebarMargin) && double.TryParse(SidebarMargin.Replace("px", ""), out var marginVal))
                {
                    sidebarWidth = marginVal;
                }

                ViewportWidth = Math.Max(100, m.WindowWidth - sidebarWidth - m.PixelManagerWidth - m.MainHPad - safetyPadding);
                ViewportHeight = Math.Max(100, m.WindowHeight - m.MainVPad - safetyPadding);
            }
        }
        catch (Exception ex)
        {
            _nlog.Warn(ex, "Failed to calculate viewport dimensions");
        }
    }

    private record ElementSize(double Width, double Height);
    private record LayoutMetrics(double WindowWidth, double WindowHeight, double MainHPad, double MainVPad, double PixelManagerWidth);

    protected override async Task OnParametersSetAsync()
    {
        var requestedCanvasName = canvasName;
        var loadVersion = System.Threading.Interlocked.Increment(ref _canvasLoadVersion);

        if (_hasRendered && _lastSidebarMargin != SidebarMargin)
        {
            _lastSidebarMargin = SidebarMargin;
            _pendingViewportRefresh = true;
        }
        
        if (_hubConnection?.State == HubConnectionState.Connected && _connectedGroup != requestedCanvasName)
        {
            if (!string.IsNullOrEmpty(_connectedGroup))
            {
                await _hubConnection.InvokeAsync("LeaveCanvasGroup", _connectedGroup);
            }
            await _hubConnection.InvokeAsync("JoinCanvasGroup", requestedCanvasName);
            _connectedGroup = requestedCanvasName;
        }

        if (_loadedCanvasName == requestedCanvasName && _canvas != null)
            return;

        _canvasReady = false;
        _canvas = null;
        _loadedCanvasName = requestedCanvasName;
        _pendingViewportRefresh = true;

        if (_renderer != null)
        {
            await _renderer.DisposeAsync();
            _renderer = null;
        }

        _jsViewportInitialized = false;

        try
        {
            if (_colors is null)
            {
                _colors = await ApiClient.GetColorsAsync();
            }
            if (loadVersion != _canvasLoadVersion || requestedCanvasName != canvasName) return;

            var loadedCanvas = await ApiClient.GetCanvas(requestedCanvasName);
            if (loadVersion != _canvasLoadVersion || requestedCanvasName != canvasName) return;

            _canvas = loadedCanvas;

            await LoadCanvasImage(loadVersion);

             if (_hubConnection?.State == HubConnectionState.Connected && _connectedGroup != requestedCanvasName)
            {
                if (!string.IsNullOrEmpty(_connectedGroup)) await _hubConnection.InvokeAsync("LeaveCanvasGroup", _connectedGroup);
                await _hubConnection.InvokeAsync("JoinCanvasGroup", requestedCanvasName);
                _connectedGroup = requestedCanvasName;
            }

            _clickedPixel = null;
            _clickedPixelData = null;

            if (_hasRendered && _renderer != null)
            {
                await InitJsViewport();
            }
        }
        catch (Exception ex)
        {
            _nlog.Warn(ex, "Failed to load canvas {0}", canvasName);
        }
    }

    private async Task LoadCanvasImage(int? loadVersion = null)
    {
        if (_canvas == null || _renderer == null) return;
        try
        {
            var canvasSnapshot = _canvas;
            var versionSnapshot = loadVersion ?? _canvasLoadVersion;

            var imageBytes = await ApiClient.GetCanvasImage(canvasSnapshot);
            if (versionSnapshot != _canvasLoadVersion || !ReferenceEquals(canvasSnapshot, _canvas) || _renderer == null) return;

            await _renderer.LoadImageAsync(imageBytes);
        }
        catch (Exception ex)
        {
            _nlog.Warn(ex, "Failed to load image for canvas {0}", canvasName);
        }
    }

    private async Task NotifyAsync(CustomNotification note)
    {
        try
        {
            await NotificationService.Writer.WriteAsync(note);
        }
        catch (Exception ex)
        {
            _nlog.Warn(ex, "NotificationService.Writer.WriteAsync failed");
        }
    }

    public async ValueTask DisposeAsync()
    {
        _canvasReady = false;

        try { await JSRuntime.InvokeVoidAsync("canvasViewport.dispose"); } catch { }

        if (_resizeListener != null)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("canvasHelpers.unregisterResizeListener", _resizeListener);
                await _resizeListener.DisposeAsync();
            }
            catch { }
        }

        _objRef?.Dispose();

        if (_renderer != null)
        {
            await _renderer.DisposeAsync();
        }
        
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
