@page "/canvas/{canvasName}"
@using Linteum.BlazorApp.Components.Layout
@layout BaseLayout

<div class="canvas-page-container"
     style="--sidebar-margin:@SidebarMargin;">
    @if (!_canvasReady)
    {
        <div class="canvas-loading-overlay">
            <div class="loading-spinner"></div>
            @if (_initTimedOut)
            {
                <div class="canvas-loading-retry">
                    <span>Taking longer than expected to load the canvas.</span>
                    <button type="button" class="canvas-retry-button"
                            disabled="@_retryInProgress"
                            @onclick="RetryInitializationAsync">
                        Retry
                    </button>
                </div>
            }
            else if (_initSecondsRemaining > 0)
            {
                <div class="canvas-loading-countdown">@_initSecondsRemaining</div>
            }
        </div>
    }

    @if (_canvas != null
         && (_connectionStatus == HubConnectionStatus.Reconnecting
             || _connectionStatus == HubConnectionStatus.Disconnected))
    {
        <div class="canvas-connection-banner @(_connectionStatus.ToString().ToLowerInvariant())">
            <span class="canvas-connection-banner-text">
                <span class="canvas-connection-dot"></span>
                @if (_connectionStatus == HubConnectionStatus.Reconnecting)
                {
                    <text>Reconnecting…</text>
                }
                else
                {
                    <text>Realtime connection lost</text>
                }
            </span>
            @if (_connectionStatus == HubConnectionStatus.Disconnected)
            {
                <button type="button" class="canvas-retry-button"
                        disabled="@_retryInProgress"
                        @onclick="RetryInitializationAsync">
                    Retry
                </button>
            }
        </div>
    }

    @if (_canvas != null)
    {
        <div class="canvas-shell @(_canvasReady ? "ready" : "")">
            <div @ref="_viewportHostRef" class="canvas-stage">
                <div @ref="_viewportRef" class="canvas-viewport"
                     style="width:@(ViewportWidth)px; height:@(ViewportHeight)px;">

                    <div @ref="_rendererRef" class="canvas-renderer"
                         style="position: absolute; background:#ffffff;">

                        <canvas @ref="_canvasRef"
                                class="canvas-surface"
                                width="@_canvas.Width"
                                height="@_canvas.Height">
                        </canvas>

                        <canvas @ref="_overlayRef"
                                class="canvas-surface canvas-surface--overlay"
                                width="@_canvas.Width"
                                height="@_canvas.Height">
                        </canvas>

                        @if (ShowTextCaret)
                        {
                            <div class="canvas-text-caret" style="@(GetTextCaretStyle())"></div>
                        }

                    </div>
                </div>
            </div>

            <PixelManager @ref="_pixelManager" Canvas="@_canvas" ClickedPixel="@_clickedPixel" ClickedPixelData="@_clickedPixelData" CanvasRenderer="@_renderer" Gold="@_gold" OnlineUsers="@_onlineUsers" IsMobileLayout="@_isMobileLayout" MaintenanceProgress="@_maintenanceProgress" OnEconomyBalanceChanged="RefreshGoldAsync" OnTextCaretPreviewChanged="HandleTextCaretPreviewChanged" OnTextSelectionPersistenceChanged="HandleTextSelectionPersistenceChanged" IsBrushEnabled="@_isBrushEnabled" IsBrushEnabledChanged="HandleBrushToggledAsync" IsEraserBrushEnabled="@_isEraserBrushEnabled" IsEraserBrushEnabledChanged="HandleEraserBrushToggledAsync" SelectedEraserSize="@_selectedEraserSize" SelectedEraserSizeChanged="HandleSelectedEraserSizeChangedAsync" SelectedBrushColorHexChanged="HandleSelectedBrushColorHexChangedAsync" OnCanvasErased="HandleCanvasErasedLocallyAsync" OnCanvasDeleted="HandleCanvasDeletedLocallyAsync" />
        </div>

        <div @ref="_coordsDisplayRef" class="canvas-coordinates"
             style="left: calc(@(SidebarMargin) + 12px);"></div>

        <CanvasLobbyChat CanvasName="@_canvas.Name"
                         CurrentUserName="@_currentUserName"
                         State="@CurrentChatState"
                         OnSend="SendCanvasChatMessageAsync" />

    }
</div>

