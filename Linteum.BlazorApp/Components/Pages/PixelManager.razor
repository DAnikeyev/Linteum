@using Linteum.Shared.DTO
@using Linteum.BlazorApp.Components.Notification
@using Linteum.BlazorApp.Services
@using Linteum.Shared
@inject MyApiClient ApiClient
@inject NotificationService NotificationService

<div class="pixelmanager">
    <div class="pm-header">
        @if (Canvas == null)
        {
            <span class="pm-title">Canvas not loaded</span>
        }
        else
        {
            <span class="pm-title">@Canvas.Name : (@Canvas.Width x @Canvas.Height)</span>
        }
    </div>

    <div class="pm-content">
        @if (Canvas?.CanvasMode == CanvasMode.Economy)
        {
            <div class="pm-gold">Gold: @Gold <span class="pm-coin">🪙</span></div>
        }

        <div class="pm-drawing">
            <h6>Pixel Drawing</h6>

            <div class="pm-fields">
                <div class="pm-field">
                    <label class="form-label">Selected Pixel</label>
                    @if (ClickedPixel.HasValue)
                    {
                        <div>X: @ClickedPixel.Value.X, Y: @ClickedPixel.Value.Y</div>
                    }
                    else
                    {
                        <div class="text-muted">No pixel selected</div>
                    }
                </div>

                <div class="pm-field">
                    <label class="form-label">Color Palette</label>
                    <div class="color-palette">
                        @if (_colors != null)
                        {
                            @foreach (var c in _colors)
                            {
                                <div class="color-square @(c.Id == _selectedColorId ? "selected" : "")" 
                                     style="background:@c.HexValue;" 
                                     title="@(string.IsNullOrEmpty(c.Name) ? c.HexValue : c.Name)"
                                     @onclick="() => SelectColor(c)">
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="pm-field pm-paint-wrap">
                    <button class="btn pm-paint-btn" @onclick="PaintClick" disabled="@(SelectedColor == null || !ClickedPixel.HasValue)">Paint</button>
                </div>
            </div>
        </div>

        <div class="pm-online-users">
            <h6>Online Users (@OnlineUsers.Count)</h6>
            <div class="pm-user-list">
                @if (OnlineUsers.Any())
                {
                    @foreach (var user in OnlineUsers)
                    {
                        <span class="pm-user-chip">@user</span>
                    }
                }
                else
                {
                    <span class="pm-user-empty">Only you are here</span>
                }
            </div>
        </div>

        @if (_pixelChangeHistory != null && _pixelChangeHistory.Any())
        {
            <div class="pm-history">
                <h6>Pixel History</h6>
                <div class="history-list">
                    @foreach (var item in _pixelChangeHistory)
                    {
                        var oldColor = _colors?.FirstOrDefault(c => c.Id == item.OldColorId);
                        var newColor = _colors?.FirstOrDefault(c => c.Id == item.NewColorId);

                        <div class="history-item">
                            <div class="history-colors">
                                <div class="color-swatch-sm" style="background:@(oldColor?.HexValue ?? "transparent");" title="Old: @(oldColor?.Name ?? "?")"></div>
                                <span class="arrow">→</span>
                                <div class="color-swatch-sm" style="background:@(newColor?.HexValue ?? "transparent");" title="New: @(newColor?.Name ?? "?")"></div>
                            </div>
                            <div class="history-details">
                                <span class="username">@item.UserName</span>
                                <span class="timestamp">@item.Timestamp.ToLocalTime().ToString("g")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public CanvasDto? Canvas { get; set; }

    [Parameter]
    public (int X, int Y)? ClickedPixel { get; set; }

    [Parameter]
    public CanvasRenderer? CanvasRenderer { get; set; }

    [Parameter]
    public PixelDto? ClickedPixelData { get; set; }

    public long Gold { get; set; }

    [Parameter]
    public List<string> OnlineUsers { get; set; } = new();

    private static readonly NLog.Logger _nlog = NLog.LogManager.GetCurrentClassLogger();
    private List<ColorDto>? _colors;
    private List<HistoryResponseItem>? _pixelChangeHistory;
    private Guid? PrevPixelId;
    private (int X, int Y)? _prevClickedPixel;
    private int? _selectedColorId;
    private ColorDto? SelectedColor => _colors?.FirstOrDefault(c => c.Id == _selectedColorId);

    protected override async Task OnInitializedAsync()
    {
        _colors = await ApiClient.GetColorsAsync();
        if (_colors != null)
        {
            _colors = _colors
                .Select(c => new { Color = c, Hsv = ColorToHsv(c.HexValue) })
                .OrderBy(x => x.Hsv.h)
                .ThenBy(x => x.Hsv.s)
                .ThenBy(x => x.Hsv.v)
                .Select(x => x.Color)
                .ToList();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ClickedPixelData == null || !ClickedPixel.HasValue)
        {
            PrevPixelId = null;
            _prevClickedPixel = null;
            _pixelChangeHistory = null;
            return;
        }

        if (ClickedPixelData.Id == null)
        {
            // Pixel has never been changed before - clear stale history from previously selected pixels.
            PrevPixelId = null;
            _prevClickedPixel = ClickedPixel;
            _pixelChangeHistory = null;
            return;
        }

        var samePixel =
            _prevClickedPixel.HasValue &&
            _prevClickedPixel.Value.X == ClickedPixel.Value.X &&
            _prevClickedPixel.Value.Y == ClickedPixel.Value.Y;

        if (samePixel && PrevPixelId.HasValue && PrevPixelId.Value == ClickedPixelData.Id.Value)
        {
            return;
        }

        _prevClickedPixel = ClickedPixel;
        PrevPixelId = ClickedPixelData.Id.Value;
        _pixelChangeHistory = await ApiClient.GetHistoryAsync(ClickedPixelData.Id.Value, useCache: true);
    }

    public async Task UpdatePixelHistory()
    {
        if (ClickedPixelData?.Id != null)
        {
            _pixelChangeHistory = await ApiClient.GetHistoryAsync(ClickedPixelData.Id.Value, useCache: false);
            StateHasChanged();
        }
    }

    private void SelectColor(ColorDto c)
    {
        _selectedColorId = c.Id;
    }

    private (double h, double s, double v) ColorToHsv(string hex)
    {
        if (string.IsNullOrEmpty(hex)) return (0, 0, 0);
        hex = hex.TrimStart('#');
        if (hex.Length != 6) return (0, 0, 0);

        try
        {
            int r = int.Parse(hex.Substring(0, 2), System.Globalization.NumberStyles.HexNumber);
            int g = int.Parse(hex.Substring(2, 2), System.Globalization.NumberStyles.HexNumber);
            int b = int.Parse(hex.Substring(4, 2), System.Globalization.NumberStyles.HexNumber);

            double doubleR = r / 255.0;
            double doubleG = g / 255.0;
            double doubleB = b / 255.0;

            double max = Math.Max(doubleR, Math.Max(doubleG, doubleB));
            double min = Math.Min(doubleR, Math.Min(doubleG, doubleB));
            double delta = max - min;

            double h = 0;
            if (delta > 0)
            {
                if (Math.Abs(max - doubleR) < 0.0001) h = 60 * (((doubleG - doubleB) / delta) % 6);
                else if (Math.Abs(max - doubleG) < 0.0001) h = 60 * (((doubleB - doubleR) / delta) + 2);
                else if (Math.Abs(max - doubleB) < 0.0001) h = 60 * (((doubleR - doubleG) / delta) + 4);
            }
            if (h < 0) h += 360;

            double s = max == 0 ? 0 : delta / max;
            double v = max;

            return (h, s, v);
        }
        catch
        {
            return (0, 0, 0);
        }
    }

    private async Task PaintClick()
    {
        if (Canvas == null)
        {
            await NotifyAsync( new CustomNotification
            {
                Message = "No canvas loaded.",
                Type = NotificationType.Info,
            });
            return;
        }

        if(SelectedColor == null || !ClickedPixel.HasValue)
        {
            await NotifyAsync( new CustomNotification
            {
                Message = "No color selected or pixel clicked.",
                Type = NotificationType.Info,
            });
            return;
        }

        try
        {
            var newPixel = await ApiClient.Paint(ClickedPixel.Value, Canvas, SelectedColor.Id);
            if (CanvasRenderer != null)
            {
                CanvasRenderer.EnqueuePixel(newPixel.X, newPixel.Y, SelectedColor.HexValue);
            }

            await NotifyAsync(new CustomNotification
            {
                Message = $"Painted pixel at ({newPixel.X}, {newPixel.Y}) with color {SelectedColor.Name ?? SelectedColor.HexValue}.",
                Type = NotificationType.Success,
            });
            if (newPixel.Id.HasValue)
            {
                PrevPixelId = newPixel.Id.Value;
                _prevClickedPixel = ClickedPixel;
                _pixelChangeHistory = await ApiClient.GetHistoryAsync(newPixel.Id.Value, useCache: false);
            }
        }
        catch (Exception ex)
        {
            _nlog.Error(ex, "Error painting pixel");
            await NotifyAsync( new CustomNotification
            {
                Message = $"Error painting pixel: {ex.Message}",
                Type = NotificationType.Error,
            });
        }
    }

    private async Task NotifyAsync(CustomNotification note)
    {
        try
        {
            await NotificationService.Writer.WriteAsync(note);
        }
        catch (Exception ex)
        {
            _nlog.Warn(ex, "NotificationService.Writer.WriteAsync failed in PixelManager");
        }
    }
}
